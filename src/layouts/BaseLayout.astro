---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<title>earthtomemphis</title>
	</head>
	<body class="font-sans text-espresso antialiased">
		<!-- ── Nav ── -->
		<header
			class="bg-cream/90 backdrop-blur-sm sticky top-0 z-30 border-b border-stone/30"
		>
			<div
				class="max-w-6xl mx-auto px-6 md:px-10 py-4 flex items-center justify-between"
			>
				<a
					href="index.html"
					class="font-serif text-xl tracking-tight"
					>earthtomemphis</a
				>
				<nav
					class="hidden md:flex items-center gap-7 text-sm font-medium text-espresso/70"
				>
					<a
						href="journal.html"
						class="hover:text-camel transition-colors"
						>Journal</a
					>
					<a
						href="journal.html"
						class="hover:text-camel transition-colors"
						>Destinations</a
					>
					<a
						href="journal.html"
						class="hover:text-camel transition-colors"
						>Budget Tips</a
					>
					<a
						href="journal.html"
						class="hover:text-camel transition-colors"
						>Food</a
					>
					<a
						href="about.html"
						class="hover:text-camel transition-colors"
						>About</a
					>
				</nav>
				<a
					href="https://youtube.com/@earthtomemphis"
					target="_blank"
					class="flex items-center gap-2 bg-espresso text-cream text-xs font-semibold px-4 py-2.5 hover:bg-camel transition-colors"
				>
					<svg
						class="w-3.5 h-3.5"
						fill="currentColor"
						viewBox="0 0 24 24"
						><path
							d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8ZM9.75 15.5v-7l6.25 3.5-6.25 3.5Z"
						></path></svg
					>
					Subscribe
				</a>
			</div>
		</header>

		<slot />

		<!-- ── Newsletter ── -->
		<section class="bg-sage text-cream">
			<div
				class="max-w-3xl mx-auto px-6 md:px-10 py-20 text-center"
			>
				<p
					class="font-mono text-xs text-cream/60 tracking-widest mb-4"
				>
					DON'T MISS A POST
				</p>
				<h2 class="font-serif text-3xl md:text-4xl">
					Get the next one in your inbox
				</h2>
				<p
					class="mt-4 text-cream/70 max-w-md mx-auto leading-relaxed"
				>
					New destinations, budget breakdowns, and the
					YouTube video I just dropped — once a week, no
					spam.
				</p>
				<form
					class="mt-9 flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto"
				>
					<input
						type="email"
						placeholder="your@email.com"
						class="flex-1 bg-transparent border border-cream/40 text-cream placeholder-cream/40 px-4 py-3 text-sm focus:outline-none focus:border-cream"
					/>
					<button
						type="button"
						class="bg-cream text-espresso px-6 py-3 text-sm font-semibold hover:bg-sand transition-colors"
					>
						Subscribe
					</button>
				</form>
			</div>
		</section>

		<!-- ── Footer ── -->
		<footer class="bg-espresso text-cream">
			<div
				class="max-w-6xl mx-auto px-6 md:px-10 py-14 grid sm:grid-cols-3 gap-10"
			>
				<div>
					<p class="font-serif text-xl mb-3">
						earthtomemphis
					</p>
					<p class="text-sm text-stone leading-relaxed">
						Solo travel, honest budgets, and the places
						worth the detour.
					</p>
					<p class="font-mono text-xs text-stone/50 mt-5">
						Currently somewhere with bad Wi-Fi.
					</p>
				</div>
				<div>
					<p
						class="font-mono text-xs text-stone tracking-widest uppercase mb-4"
					>
						Explore
					</p>
					<ul class="space-y-2 text-sm text-cream/70">
						<li>
							<a
								href="journal.html"
								class="hover:text-camel transition-colors"
								>Journal</a
							>
						</li>
						<li>
							<a
								href="journal.html"
								class="hover:text-camel transition-colors"
								>Destinations</a
							>
						</li>
						<li>
							<a
								href="journal.html"
								class="hover:text-camel transition-colors"
								>Budget Tips</a
							>
						</li>
						<li>
							<a
								href="about.html"
								class="hover:text-camel transition-colors"
								>About</a
							>
						</li>
					</ul>
				</div>
				<div>
					<p
						class="font-mono text-xs text-stone tracking-widest uppercase mb-4"
					>
						Follow
					</p>
					<ul class="space-y-2 text-sm text-cream/70">
						<li>
							<a
								href="https://youtube.com/@earthtomemphis"
								target="_blank"
								class="hover:text-camel transition-colors"
								>YouTube</a
							>
						</li>
						<li>
							<a
								href="#"
								class="hover:text-camel transition-colors"
								>Instagram</a
							>
						</li>
						<li>
							<a
								href="#"
								class="hover:text-camel transition-colors"
								>TikTok</a
							>
						</li>
					</ul>
				</div>
			</div>
			<div
				class="border-t border-stone/20 text-center text-xs text-stone/40 py-5"
			>
				© 2026 earthtomemphis · Made with two feet on the
				ground.
			</div>
		</footer>
	</body>
</html>
